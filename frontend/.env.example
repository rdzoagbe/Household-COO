# Household COO frontend environment
# Copy this file to .env and replace the placeholders with real values.

# Backend API used by the Expo app.
EXPO_PUBLIC_BACKEND_URL=https://household-coo-production.up.railway.app

# Google OAuth client IDs.
# IMPORTANT:
# - The WEB client ID must come from an OAuth client of type "Web application".
# - The ANDROID client ID must come from an OAuth client of type "Android".
# - Do not use the same value for both unless Google Cloud explicitly created the same value, which is unusual.
# - Android package name: com.householdcoo.app
# - Local debug SHA-1 used by npx expo run:android on Roland's PC:
#   84:C1:B5:CF:DE:FD:B4:B7:24:DE:A6:8C:C6:10:88:77:EE:56:D7:81
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_REAL_WEB_CLIENT_ID.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=YOUR_REAL_ANDROID_CLIENT_ID.apps.googleusercontent.com
