              <div><b>Vendor:</b> {extracted.vendor}</div>
              <div><b>Term:</b> {extracted.term}</div>
              <div><b>Auto-renew:</b> {extracted.autoRenew}</div>
              <div><b>Termination window:</b> {extracted.terminationWindow}</div>
              <div><b>Price increase:</b> {extracted.priceIncrease}</div>
              <div><b>Minimum commitment:</b> {extracted.minimumCommitment}</div>
            </div>
          </Card>
          <Card title="Recommended action">
            <div className="text-sm">{extracted.notes}</div>
            <div className="mt-3 flex gap-2">
              <Link to="/renewals"><Button>Open renewals</Button></Link>
              <Link to="/actions"><Button variant="secondary">Add to actions</Button></Link>
            </div>
          </Card>
        </div>
      )}
    </Page>
  );
}

function Invoices() {
  const [rows, setRows] = useState(seed.invoices);
  const [status, setStatus] = useState("all");
  const [file, setFile] = useState(null);

  const filtered = useMemo(() => {
    if (status === "all") return rows;
    return rows.filter((r) => r.status === status);
  }, [rows, status]);

  const upload = () => {
    if (!file) return;
    setRows((prev) => [
      { id: `inv-${prev.length + 1}`, vendor: "New Vendor", amount: 1500, status: "pending", date: "2026-02-24" },
      ...prev,
    ]);
    setFile(null);
    alert("Invoice uploaded (mock). Replace with storage + OCR/vendor extraction.");
  };

  const setInvoiceStatus = (id, next) => {
    setRows((prev) => prev.map((r) => (r.id === id ? { ...r, status: next } : r)));
  };

  const exportReport = () => {
    const header = ["vendor", "amount", "status", "date"];
    const lines = filtered.map((r) => [r.vendor, r.amount, r.status, r.date].join(","));
    const csv = [header.join(","), ...lines].join("\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "invoices.csv";
    a.click();
    URL.revokeObjectURL(url);
  };

  return (
    <Page
      title="Invoice Manager"
      subtitle="Streamlined approval flow with exports"
      right={
        <div className="flex gap-2 items-center">
          <select className="border rounded-xl px-3 py-2 text-sm bg-white" value={status} onChange={(e) => setStatus(e.target.value)}>
            <option value="all">All</option>
            <option value="pending">Pending</option>
            <option value="approved">Approved</option>
            <option value="rejected">Rejected</option>
          </select>
          <Button variant="secondary" onClick={exportReport}>Export report</Button>
        </div>
      }
    >
      <Card title="Upload invoice (demo)">
        <div className="flex flex-col md:flex-row gap-3 items-start md:items-center">
          <input type="file" className="text-sm" onChange={(e) => setFile(e.target.files?.[0] || null)} />
          <Button onClick={upload} disabled={!file}>Upload</Button>
          <div className="text-xs text-gray-500">Add OCR + vendor mapping later.</div>
        </div>
      </Card>

      <div className="mt-4">
        <Card title="Invoices (demo)">
          <div className="space-y-2">
            {filtered.map((r) => (
              <div key={r.id} className="p-3 rounded-2xl border bg-white flex items-center justify-between">
                <div>
                  <div className="font-medium">{r.vendor}</div>
                  <div className="text-xs text-gray-500 mt-1">{r.date} • {formatCurrency(r.amount, seed.company.currency)}</div>
                </div>
                <div className="flex items-center gap-2">
                  <Pill tone={r.status === "approved" ? "green" : r.status === "rejected" ? "red" : "yellow"}>{r.status}</Pill>
                  {r.status === "pending" && (
                    <>
                      <Button onClick={() => setInvoiceStatus(r.id, "approved")}>Approve</Button>
                      <Button variant="danger" onClick={() => setInvoiceStatus(r.id, "rejected")}>Reject</Button>
                    </>
                  )}
                  <KebabMenu
                    items={[
                      { label: "View details (mock)", onClick: () => alert("Invoice details modal (mock).") },
                      { label: "Assign owner (mock)", onClick: () => alert("Assign owner (mock).") },
                    ]}
                  />
                </div>
              </div>
            ))}
          </div>
        </Card>
      </div>
    </Page>
  );
}

function Procurement() {
  const [requests, setRequests] = useState(() => [
    { id: "pr-1", requester: "Alice", tool: "Figma", amount: 2400, status: "pending", dept: "Design" },
    { id: "pr-2", requester: "Ben", tool: "Datadog", amount: 12000, status: "approved", dept: "Engineering" },
  ]);

  const [draft, setDraft] = useState({ requester: "", tool: "", amount: 0, dept: "Engineering" });

  const submit = () => {
    setRequests((prev) => [{ id: `pr-${prev.length + 1}`, ...draft, status: "pending" }, ...prev]);
    setDraft({ requester: "", tool: "", amount: 0, dept: "Engineering" });
  };

  const updateStatus = (id, status) => setRequests((prev) => prev.map((r) => (r.id === id ? { ...r, status } : r)));

  return (
    <Page title="Procurement Workflow" subtitle="Request → approval → tracking (demo)">
      <Card title="New request">
        <div className="grid md:grid-cols-4 gap-3 text-sm">
          <input className="border rounded-xl px-3 py-2 bg-white" placeholder="Requester" value={draft.requester} onChange={(e) => setDraft((d) => ({ ...d, requester: e.target.value }))} />
          <input className="border rounded-xl px-3 py-2 bg-white" placeholder="Tool" value={draft.tool} onChange={(e) => setDraft((d) => ({ ...d, tool: e.target.value }))} />
          <input className="border rounded-xl px-3 py-2 bg-white" type="number" placeholder="Amount" value={draft.amount} onChange={(e) => setDraft((d) => ({ ...d, amount: Number(e.target.value || 0) }))} />
          <select className="border rounded-xl px-3 py-2 bg-white" value={draft.dept} onChange={(e) => setDraft((d) => ({ ...d, dept: e.target.value }))}>
            <option>Engineering</option><option>Sales</option><option>Marketing</option><option>Operations</option><option>Design</option>
          </select>
        </div>
        <div className="mt-3">
          <Button onClick={submit} disabled={!draft.requester || !draft.tool || !draft.amount}>Submit</Button>
        </div>
      </Card>

      <div className="mt-4">
        <Card title="Requests">
          <div className="space-y-2">
            {requests.map((r) => (
              <div key={r.id} className="p-3 rounded-2xl border bg-white flex items-center justify-between">
                <div>
                  <div className="font-medium">{r.tool}</div>
                  <div className="text-xs text-gray-500 mt-1">{r.requester} • {r.dept} • {formatCurrency(r.amount, seed.company.currency)}</div>
                </div>
                <div className="flex items-center gap-2">
                  <Pill tone={r.status === "approved" ? "green" : r.status === "rejected" ? "red" : "yellow"}>{r.status}</Pill>
                  {r.status === "pending" && (
                    <>
                      <Button onClick={() => updateStatus(r.id, "approved")}>Approve</Button>
                      <Button variant="danger" onClick={() => updateStatus(r.id, "rejected")}>Reject</Button>
                    </>
                  )}
                  <KebabMenu
                    items={[
                      { label: "Route to Legal (mock)", onClick: () => alert("Legal review (mock).") },
                      { label: "Check overlap (mock)", onClick: () => alert("Overlap check (mock).") },
                    ]}
                  />
                </div>
              </div>
            ))}
          </div>
        </Card>
      </div>
    </Page>
  );
}

function BudgetsForecast() {
  const rows = seed.budgets;
  const over = rows.filter((r) => r.actual > r.monthlyBudget);
  const totalOver = over.reduce((s, r) => s + (r.actual - r.monthlyBudget), 0);

  return (
    <Page title="Budgets & Forecast" subtitle="Department budgets vs actual with forecast alerts">
      <div className="grid md:grid-cols-3 gap-4">
        <Card title="Departments over budget">
          <div className="text-3xl font-semibold">{over.length}</div>
          <div className="text-xs text-gray-500 mt-1">This month (demo)</div>
        </Card>
        <Card title="Overage amount">
          <div className="text-3xl font-semibold">{formatCurrency(totalOver, seed.company.currency)}</div>
          <div className="text-xs text-gray-500 mt-1">Immediate savings target</div>
        </Card>
        <Card title="Next best action">
          <div className="text-sm">Open Action Center and apply the top 3 savings actions.</div>
          <div className="mt-3"><Link to="/actions"><Button>Go</Button></Link></div>
        </Card>
      </div>

      <div className="mt-4">
        <Card title="Budget table (demo)">
          <div className="overflow-auto">
            <table className="min-w-full text-sm">
              <thead className="text-xs text-gray-500">
                <tr className="border-b">
                  <th className="text-left py-2 pr-3">Department</th>
                  <th className="text-right py-2 pr-3">Budget</th>
                  <th className="text-right py-2 pr-3">Actual</th>
                  <th className="text-right py-2 pr-3">Variance</th>
                  <th className="text-right py-2 pr-3">Status</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((r) => {
                  const variance = r.actual - r.monthlyBudget;
                  const ok = variance <= 0;
                  return (
                    <tr key={r.dept} className="border-b">
                      <td className="py-2 pr-3 font-medium">{r.dept}</td>
                      <td className="py-2 pr-3 text-right">{formatCurrency(r.monthlyBudget, seed.company.currency)}</td>
                      <td className="py-2 pr-3 text-right">{formatCurrency(r.actual, seed.company.currency)}</td>
                      <td className="py-2 pr-3 text-right">{formatCurrency(variance, seed.company.currency)}</td>
                      <td className="py-2 pr-3 text-right">{ok ? <Pill tone="green">On track</Pill> : <Pill tone="red">Over</Pill>}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        </Card>
      </div>
    </Page>
  );
}

function SecurityRisk() {
  return (
    <Page title="Security & Risk" subtitle="Understand data exposure, compliance, and vendor dependency risk">
      <Card title="Vendors (demo)">
        <div className="overflow-auto">
          <table className="min-w-full text-sm">
            <thead className="text-xs text-gray-500">
              <tr className="border-b">
                <th className="text-left py-2 pr-3">Vendor</th>
                <th className="text-left py-2 pr-3">Data access</th>
                <th className="text-left py-2 pr-3">Compliance</th>
                <th className="text-left py-2 pr-3">Residency</th>
                <th className="text-left py-2 pr-3">Risk</th>
                <th className="text-right py-2 pr-3">Actions</th>
              </tr>
            </thead>
            <tbody>
              {seed.securityVendors.map((v) => (
                <tr key={v.vendor} className="border-b">
                  <td className="py-2 pr-3 font-medium">{v.vendor}</td>
                  <td className="py-2 pr-3">{v.dataAccess}</td>
                  <td className="py-2 pr-3">{v.compliance.join(", ")}</td>
                  <td className="py-2 pr-3">{v.residency}</td>
                  <td className="py-2 pr-3">
                    <Pill tone={v.risk === "high" ? "red" : v.risk === "med" ? "yellow" : "green"}>{v.risk}</Pill>
                  </td>
                  <td className="py-2 pr-3 text-right">
                    <div className="flex justify-end gap-2">
                      <Button variant="secondary" onClick={() => alert("Open vendor risk profile (mock).")}>Profile</Button>
                      <KebabMenu
                        items={[
                          { label: "Request SOC2 report (mock)", onClick: () => alert("Request sent (mock).") },
                          { label: "Add to review queue (mock)", onClick: () => alert("Queued (mock).") },
                        ]}
                      />
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </Card>
    </Page>
  );
}

function ExecutiveReport() {
  const totalSpend = seed.categories.reduce((a, b) => a + b.spend, 0);
  const potentialSavings = 6912 + 4752 + 3100 + 12000;
  const riskyRenewals = seed.renewals.filter((r) => r.risk === "high").length;

  const printReport = () => window.print();

  return (
    <Page
      title="Executive Report"
      subtitle="One-page summary for leadership (print/export ready)"
      right={<Button onClick={printReport}>Print / Export</Button>}
    >
      <div className="grid md:grid-cols-3 gap-4">
        <Card title="Monthly SaaS spend">
          <div className="text-3xl font-semibold">{formatCurrency(totalSpend, seed.company.currency)}</div>
          <div className="text-xs text-gray-500 mt-1">Tracked categories (demo)</div>
        </Card>
        <Card title="Identified savings">
          <div className="text-3xl font-semibold">{formatCurrency(potentialSavings, seed.company.currency)}/yr</div>
          <div className="text-xs text-gray-500 mt-1">From Action Center (demo)</div>
        </Card>
        <Card title="High-risk renewals">
          <div className="text-3xl font-semibold">{riskyRenewals}</div>
          <div className="text-xs text-gray-500 mt-1">Require negotiation</div>
        </Card>
      </div>

      <div className="mt-4 grid md:grid-cols-2 gap-4">
        <Card title="Top decisions this month">
          <ol className="text-sm space-y-2 list-decimal pl-5">
            <li>Negotiate Salesforce renewal (auto-renew ON; high spend).</li>
            <li>Reclaim idle Zoom seats and reduce plan footprint.</li>
            <li>Consolidate Notion/Confluence overlap to one system.</li>
          </ol>
        </Card>
        <Card title="Risks">
          <ul className="text-sm space-y-2">
            <li>• Vendor dependency: Salesforce high criticality</li>
            <li>• Data exposure: Notion flagged “high”</li>
            <li>• Budget variance: Marketing over budget</li>
          </ul>
        </Card>
      </div>
    </Page>
  );
}

// -----------------------------
// Routes
// -----------------------------
function AppRoutes() {
  return (
    <AppShell>
      <AuthRedirectGate>
        <Routes>
        {/* Public */}
        <Route path="/" element={<Landing />} />
        <Route path="/login" element={<Login />} />

        {/* Protected */}
        <Route element={<RequireAuth />}>
          <Route path="/dashboard" element={<Dashboard />} />
          <Route path="/actions" element={<ActionCenter />} />
          <Route path="/licenses" element={<Licenses />} />
          <Route path="/overlap" element={<OverlapScanner />} />
          <Route path="/renewals" element={<Renewals />} />
          <Route path="/contracts" element={<ContractIntelligence />} />
          <Route path="/invoices" element={<Invoices />} />
          <Route path="/procurement" element={<Procurement />} />
          <Route path="/budgets" element={<BudgetsForecast />} />
          <Route path="/security" element={<SecurityRisk />} />
          <Route path="/executive" element={<ExecutiveReport />} />
        </Route>

        <Route path="*" element={<Navigate to="/" replace />} />
      </Routes>
      </AuthRedirectGate>
    </AppShell>
  );
}

// -----------------------------
// App
// -----------------------------
export default function App() {
  return (
    <DemoAuthProvider>
      <Router>
        <AppRoutes />
      </Router>
    </DemoAuthProvider>
  );
}
