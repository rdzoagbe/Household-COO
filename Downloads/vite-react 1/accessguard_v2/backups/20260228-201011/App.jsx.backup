


function useAuth() {
  const [user, setUser] = React.useState(null);
  const [loading, setLoading] = React.useState(true);

  React.useEffect(() => {
    const unsub = onAuthStateChanged(auth, (u) => {
      setUser(u);
      setLoading(false);
    });
    return () => unsub();
  }, []);

  return { user, loading };
}

function AuthRedirectGate({ children }) {
  const { firebaseUser, loading } = useAuth();
  const navigate = useNavigate();
  const location = useLocation();

  useEffect(() => {
    let cancelled = false;

    async function run() {
      if (loading) return;

      // If signed in, route to dashboard or onboarding (without reloading page)
      if (firebaseUser) {
        const { user: userData, error } = await getUserProfile(firebaseUser.uid);
        const completed = Boolean(
          userData?.onboardingCompleted || userData?.onboardingComplete
        );

        // Only auto-redirect from public/auth-related pages
        const p = location.pathname;
        const isPublicEntry =
          p === "/" || p === "/login" || p === "/finish-signup" || p === "/onboarding";

        if (!cancelled && isPublicEntry) {
          navigate(completed ? "/dashboard" : "/onboarding", { replace: true });
        }

        // If profile fetch failed, still take them somewhere useful
        if (!cancelled && isPublicEntry && error) {
          navigate("/dashboard", { replace: true });
        }
      }
    }

    run();

    return () => {
      cancelled = true;
    };
  }, [firebaseUser, loading, location.pathname, navigate]);

  return children;
}
/**
 * AccessGuard — single-file App.jsx (drop-in demo)
 * -------------------------------------------------
 * This file is intentionally self-contained so you can run it immediately.
 *
 * What it includes (working):
 * - Public Landing w/ ROI calculator + "How it works" scroll
 * - Finance Dashboard (filters + exports placeholder)
 * - Action Center (waste → recommended actions → apply)
 * - License Management (reclaim, export CSV, Auto-Reclaim All)
 * - Renewal Alerts (list/calendar toggle, review modal, negotiation template)
 * - Invoice Manager (upload mock, filter, export CSV, approve/reject)
 * - Tool Overlap Scanner
 * - Contract Intelligence (upload placeholder → extracted terms)
 * - Procurement Workflow (request → approve/reject)
 * - Budgets & Forecast
 * - Security & Risk
 * - Executive One-Page report (print/export)
 * - Reusable Modal + Kebab dropdown (“…”) menus
 * - Protected routes via a simple Demo Auth gate (toggle sign-in/out)
 *
 * Integration note:
 * If your project already has Firebase auth + onboarding, you can:
 * - Replace DemoAuthProvider with your AuthProvider,
 * - Replace useDemoAuth() with your existing auth hook/context,
 * - Keep the routing structure (public "/" + protected app routes).
 */

// -----------------------------
// Utilities
// -----------------------------
function cx(...classes) {
  return classes.filter(Boolean).join(" ");
}

function formatCurrency(amount, currency = "€") {
  const n = Number(amount || 0);
  return `${currency}${Math.round(n).toLocaleString()}`;
}

// -----------------------------
// Demo Auth (replace with Firebase)
// -----------------------------
const DemoAuthContext = React.createContext(null);

function DemoAuthProvider({ children }) {
  const [user, setUser] = useState(() => {
    // Keep signed-in state across refresh in demo mode
    const raw = localStorage.getItem("ag_demo_user");
    return raw ? JSON.parse(raw) : null;
  });

  useEffect(() => {
    if (user) localStorage.setItem("ag_demo_user", JSON.stringify(user));
    else localStorage.removeItem("ag_demo_user");
  }, [user]);

  const signIn = () => setUser({ email: "demo@accessguard.local", role: "admin" });
  const signOut = () => setUser(null);

  const value = useMemo(() => ({ user, signIn, signOut }), [user]);
  return <DemoAuthContext.Provider value={value}>{children}</DemoAuthContext.Provider>;
}

function useDemoAuth() {
  const ctx = React.useContext(DemoAuthContext);
  if (!ctx) throw new Error("useDemoAuth must be used inside DemoAuthProvider");
  return ctx;
}

function RequireAuth() {
  const { user } = useDemoAuth();
  const location = useLocation();
  if (!user) return <Navigate to="/login" replace state={{ from: location.pathname }} />;
  return <Outlet />;
}

// -----------------------------
// Minimal UI primitives
// -----------------------------
function Page({ title, subtitle, right, children }) {
  return (
    <div className="p-6 max-w-6xl mx-auto">
      <div className="flex items-start justify-between gap-4">
        <div>
          <h1 className="text-2xl font-semibold">{title}</h1>
          {subtitle && <p className="text-sm text-gray-500 mt-1">{subtitle}</p>}
        </div>
        {right}
      </div>
      <div className="mt-6">{children}</div>
    </div>
  );
}

function Card({ title, right, children, className }) {
  return (
    <div className={cx("border rounded-2xl bg-white shadow-sm", className)}>
      {(title || right) && (
        <div className="px-4 py-3 border-b flex items-center justify-between">
          <div className="font-medium">{title}</div>
          {right}
        </div>
      )}
      <div className="p-4">{children}</div>
    </div>
  );
}

function Button({ children, onClick, variant = "primary", className, disabled, type = "button" }) {
  const styles =
    variant === "primary"
      ? "bg-black text-white hover:bg-gray-900"
      : variant === "secondary"
        ? "bg-white border hover:bg-gray-50"
        : variant === "danger"
          ? "bg-red-600 text-white hover:bg-red-700"
          : "bg-gray-100 hover:bg-gray-200";
  return (
    <button
      type={type}
      disabled={disabled}
      onClick={onClick}
      className={cx(
        "px-3 py-2 rounded-xl text-sm font-medium transition disabled:opacity-50 disabled:cursor-not-allowed",
        styles,
        className
      )}
    >
      {children}
    </button>
  );
}

function Pill({ children, tone = "gray" }) {
  const map = {
    gray: "bg-gray-100 text-gray-700",
    green: "bg-green-100 text-green-700",
    yellow: "bg-yellow-100 text-yellow-800",
    red: "bg-red-100 text-red-700",
    blue: "bg-blue-100 text-blue-700",
  };
  return <span className={cx("px-2 py-1 rounded-full text-xs font-medium", map[tone] || map.gray)}>{children}</span>;
}

function Modal({ open, title, children, onClose }) {
  if (!open) return null;
  return (
    <div className="fixed inset-0 bg-black/30 flex items-center justify-center p-4 z-50">
      <div className="bg-white rounded-2xl border shadow-lg max-w-lg w-full p-4">
        <div className="flex items-start justify-between gap-3">
          <div className="font-semibold text-lg">{title}</div>
          <button className="px-2 py-1 rounded-md border hover:bg-gray-50" onClick={onClose} aria-label="Close modal">
            ✕
          </button>
        </div>
        <div className="mt-3">{children}</div>
      </div>
    </div>
  );
}

function KebabMenu({ items }) {
  const [open, setOpen] = useState(false);

  useEffect(() => {
    if (!open) return;
    const onDoc = () => setOpen(false);
    document.addEventListener("click", onDoc);
    return () => document.removeEventListener("click", onDoc);
  }, [open]);

  return (
    <div className="relative inline-block text-left" onClick={(e) => e.stopPropagation()}>
      <button
        className="px-2 py-1 rounded-md border bg-white hover:bg-gray-50"
        onClick={() => setOpen((v) => !v)}
        aria-label="More actions"
      >
        ⋯
      </button>
      {open && (
        <div className="absolute right-0 mt-2 w-52 rounded-xl border bg-white shadow-lg z-50 overflow-hidden">
          {items.map((it, idx) => (
            <button
              key={idx}
              className="w-full text-left px-3 py-2 text-sm hover:bg-gray-50"
              onClick={() => {
                setOpen(false);
                it.onClick?.();
              }}
            >
              {it.label}
            </button>
          ))}
        </div>
      )}
    </div>
  );
}

