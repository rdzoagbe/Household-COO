function AppShell({ children }) {
  const location = useLocation();
  const { user, signOut } = useDemoAuth();

  const nav = [
    { to: "/", label: "Landing", public: true },
    { to: "/dashboard", label: "Finance Dashboard" },
    { to: "/actions", label: "Action Center" },
    { to: "/licenses", label: "License Management" },
    { to: "/overlap", label: "Tool Overlap" },
    { to: "/renewals", label: "Renewal Alerts" },
    { to: "/contracts", label: "Contract Intelligence" },
    { to: "/invoices", label: "Invoice Manager" },
    { to: "/procurement", label: "Procurement Workflow" },
    { to: "/budgets", label: "Budgets & Forecast" },
    { to: "/security", label: "Security & Risk" },
    { to: "/executive", label: "Executive Report" },
  ];

  const isPublicPath = location.pathname === "/" || location.pathname === "/login";

  return (
    <div className="min-h-screen bg-gray-50">
      <div className="flex">
        <aside className="w-72 bg-white border-r min-h-screen p-4 sticky top-0">
          <div className="flex items-center justify-between">
            <div>
              <div className="font-semibold text-lg">AccessGuard</div>
              <div className="text-xs text-gray-500 mt-1">All-round spend + tool control</div>
            </div>
            {user && !isPublicPath && (
              <button className="text-xs px-2 py-1 rounded-lg border hover:bg-gray-50" onClick={signOut}>
                Sign out
              </button>
            )}
          </div>

          <nav className="mt-6 space-y-1">
            {nav.map((n) => {
              const active = location.pathname === n.to;
              const disabled = !n.public && !user;
              return (
                <Link
                  key={n.to}
                  to={disabled ? "/login" : n.to}
                  className={cx(
                    "block px-3 py-2 rounded-xl text-sm",
                    active ? "bg-gray-100 font-medium" : "hover:bg-gray-50",
                    disabled && "opacity-60"
                  )}
                >
                  {n.label}
                </Link>
              );
            })}
          </nav>

          <div className="mt-8 p-3 rounded-2xl border bg-gray-50 text-xs text-gray-700">
            <div className="font-medium">Demo Mode</div>
            <div className="mt-1">
              This file runs standalone. Swap demo auth + mock data with Firebase + integrations when ready.
            </div>
          </div>
        </aside>

        <main className="flex-1">{children}</main>
      </div>
    </div>
  );
}

