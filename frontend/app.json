{
  "expo": {
    "name": "Household COO",
    "slug": "household-coo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "householdcoo",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.householdcoo.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Household COO uses the camera only when you choose Scan to capture household documents, school letters, appointment cards, or bills.",
        "NSPhotoLibraryUsageDescription": "Household COO uses your photo library only when you choose a photo to scan or attach to a household document."
      }
    },
    "android": {
      "package": "com.householdcoo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#FFB84D"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Household COO uses your photo library only when you choose a photo to scan or attach to a household document.",
          "cameraPermission": "Household COO uses the camera only when you choose Scan to capture household documents, school letters, appointment cards, or bills."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFB84D"
        }
      ],
      "expo-web-browser",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e84e02e4-5335-433f-a39c-3539c473a0dd"
      }
    }
  }
}
