function Landing() {
  const howRef = useRef(null);
  const { user } = useDemoAuth();
  const [employees, setEmployees] = useState(150);
  const [avgSaaSPerEmp, setAvgSaaSPerEmp] = useState(120);
  const [wastePct, setWastePct] = useState(0.18);

  const annualSpend = employees * avgSaaSPerEmp * 12;
  const annualWaste = annualSpend * wastePct;
  const price = 99 * 12;

  return (
    <Page
      title="Stop paying for unused SaaS"
      subtitle='A command center for spend, licenses, renewals, invoices, procurement, and risk.'
      right={
        <div className="flex gap-2">
          <Button variant="secondary" onClick={() => howRef.current?.scrollIntoView({ behavior: "smooth", block: "start" })}>
            How it works
          </Button>
          <Link to={user ? "/dashboard" : "/login"}>
            <Button>{user ? "Open app" : "Open demo"}</Button>
          </Link>
        </div>
      }
    >
      <div className="grid md:grid-cols-2 gap-4">
        <Card title="ROI Calculator" right={<Pill tone="green">Live</Pill>}>
          <div className="grid grid-cols-2 gap-3">
            <label className="text-sm">
              Employees
              <input
                className="mt-1 w-full border rounded-xl px-3 py-2 bg-white"
                type="number"
                value={employees}
                onChange={(e) => setEmployees(Number(e.target.value || 0))}
              />
            </label>
            <label className="text-sm">
              SaaS €/employee/month
              <input
                className="mt-1 w-full border rounded-xl px-3 py-2 bg-white"
                type="number"
                value={avgSaaSPerEmp}
                onChange={(e) => setAvgSaaSPerEmp(Number(e.target.value || 0))}
              />
            </label>
            <label className="text-sm col-span-2">
              Estimated waste (%)
              <input
                className="mt-1 w-full"
                type="range"
                min="0.05"
                max="0.35"
                step="0.01"
                value={wastePct}
                onChange={(e) => setWastePct(Number(e.target.value))}
              />
              <div className="text-xs text-gray-500 mt-1">{Math.round(wastePct * 100)}%</div>
            </label>
          </div>

          <div className="mt-4 grid grid-cols-3 gap-3">
            <div className="p-3 rounded-2xl bg-gray-50 border">
              <div className="text-xs text-gray-500">Annual spend</div>
              <div className="text-lg font-semibold">{formatCurrency(annualSpend, seed.company.currency)}</div>
            </div>
            <div className="p-3 rounded-2xl bg-gray-50 border">
              <div className="text-xs text-gray-500">Estimated waste</div>
              <div className="text-lg font-semibold">{formatCurrency(annualWaste, seed.company.currency)}</div>
            </div>
            <div className="p-3 rounded-2xl bg-gray-50 border">
              <div className="text-xs text-gray-500">Your cost</div>
              <div className="text-lg font-semibold">{formatCurrency(price, seed.company.currency)}/yr</div>
            </div>
          </div>

          <div className="mt-4 p-4 rounded-2xl border bg-white">
            <div className="text-sm">
              Even conservative savings can exceed{" "}
              <b>{formatCurrency(annualWaste, seed.company.currency)}</b> per year.
            </div>
            <div className="text-xs text-gray-500 mt-1">
              Demo numbers. Real savings depend on integrations + usage signals.
            </div>
          </div>
        </Card>

        <Card title="What you get">
          <ul className="space-y-2 text-sm">
            <li>• Real-time spend visibility + forecasting</li>
            <li>• License reclaim workflow with measurable ROI</li>
            <li>• Renewal alerts + negotiation support</li>
            <li>• Duplicate tool detection + consolidation plan</li>
            <li>• Contract clause extraction (auto-renew, termination windows)</li>
            <li>• Invoice approvals + exports</li>
            <li>• Procurement workflow (request → approve)</li>
