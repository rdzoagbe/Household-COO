  const location = useLocation();
  const from = location.state?.from || "/dashboard";

  return (
    <Page
      title="Sign in"
      subtitle="Demo authentication — replace with your Firebase auth flow"
      right={<Link to="/"><Button variant="secondary">Back</Button></Link>}
    >
      <Card title="Demo login">
        <div className="text-sm text-gray-600">
          Click sign in to access the app routes.
        </div>
        <div className="mt-4">
          <Link to={from} onClick={(e) => { e.preventDefault(); signIn(); window.location.href = from; }}>
            <Button>Sign in (demo)</Button>
          </Link>
        </div>
      </Card>
    </Page>
  );
}

function Dashboard() {
  const [category, setCategory] = useState("All");
  const filtered = useMemo(() => {
    if (category === "All") return seed.categories;
    return seed.categories.filter((c) => c.name === category);
  }, [category]);

  const totalSpend = seed.categories.reduce((a, b) => a + b.spend, 0);

  return (
    <Page
      title="Finance Dashboard"
      subtitle="Real-time spend tracking with category insight"
      right={
        <div className="flex gap-2 items-center">
          <select
            className="border rounded-xl px-3 py-2 text-sm bg-white"
            value={category}
            onChange={(e) => setCategory(e.target.value)}
          >
            <option>All</option>
            {seed.categories.map((c) => (
              <option key={c.name}>{c.name}</option>
            ))}
          </select>
          <KebabMenu
            items={[
              { label: "Export CSV (mock)", onClick: () => alert("Export CSV (mock). Replace with real export.") },
              { label: "Share link (mock)", onClick: () => alert("Shared link (mock).") },
            ]}
          />
        </div>
      }
    >
      <div className="grid md:grid-cols-3 gap-4">
        <Card title="Total monthly spend">
          <div className="text-3xl font-semibold">{formatCurrency(totalSpend, seed.company.currency)}</div>
          <div className="text-xs text-gray-500 mt-1">Across tracked categories (demo data)</div>
        </Card>
        <Card title="Top category">
          {(() => {
            const top = [...seed.categories].sort((a, b) => b.spend - a.spend)[0];
            return (
              <>
                <div className="text-xl font-semibold">{top.name}</div>
                <div className="text-sm text-gray-600 mt-1">
                  {formatCurrency(top.spend, seed.company.currency)} / month
                </div>
              </>
            );
          })()}
        </Card>
        <Card title="Forecast alert">
          <div className="text-sm">
            At current trend, you may exceed Q2 budget by <b>{formatCurrency(18400, seed.company.currency)}</b>.
          </div>
          <div className="mt-3">
            <Link to="/budgets"><Button variant="secondary">View budgets</Button></Link>
          </div>
        </Card>
      </div>

      <div className="mt-4 grid md:grid-cols-2 gap-4">
        <Card title="Spend by category">
          <div className="space-y-2">
            {filtered.map((c) => (
              <div key={c.name} className="flex items-center justify-between text-sm">
                <div>{c.name}</div>
                <div className="font-medium">{formatCurrency(c.spend, seed.company.currency)}</div>
              </div>
            ))}
          </div>
        </Card>

        <Card title="Recommended actions">
          <ul className="text-sm space-y-2">
            <li>• Reclaim 36 idle Zoom seats → save {formatCurrency(6912, seed.company.currency)}/year</li>
            <li>• Notion overlap with Confluence → consolidate → save {formatCurrency(9100, seed.company.currency)}/year</li>
            <li>• Salesforce auto-renew in 29 days → start negotiation</li>
          </ul>
          <div className="mt-3">
            <Link to="/actions"><Button>Open Action Center</Button></Link>
          </div>
        </Card>
      </div>
    </Page>
  );
}

function ActionCenter() {
  const [actions, setActions] = useState(() => [
    { id: "a1", type: "reclaim", title: "Reclaim 36 idle Zoom seats", impact: 6912, confidence: "high", status: "open" },
    { id: "a2", type: "downgrade", title: "Downgrade 22 Notion seats", impact: 4752, confidence: "med", status: "open" },
    { id: "a3", type: "consolidate", title: "Consolidate Miro + FigJam usage", impact: 3100, confidence: "med", status: "open" },
    { id: "a4", type: "renewal", title: "Salesforce renewal in 29 days (auto-renew ON)", impact: 12000, confidence: "high", status: "open" },
  ]);
  const [modal, setModal] = useState({ open: false, title: "", body: null });

  const totalImpact = actions.filter((a) => a.status === "open").reduce((s, a) => s + a.impact, 0);

  const apply = (id) => {
    setActions((prev) => prev.map((a) => (a.id === id ? { ...a, status: "applied" } : a)));
  };

  return (
    <Page
      title="Action Center"
      subtitle="Turn waste into measurable savings"
      right={<Pill tone="green">{formatCurrency(totalImpact, seed.company.currency)} potential</Pill>}
    >
      <Card title="Recommended actions (demo)">
        <div className="space-y-3">
          {actions.map((a) => (
            <div key={a.id} className="p-3 rounded-2xl border bg-white flex items-center justify-between gap-3">
              <div>
                <div className="font-medium">{a.title}</div>
                <div className="text-xs text-gray-500 mt-1">
                  Impact: {formatCurrency(a.impact, seed.company.currency)}/year • Confidence:{" "}
                  <span className="font-medium">{a.confidence}</span>
                </div>
              </div>
              <div className="flex items-center gap-2">
                {a.status === "open" ? (
                  <>
                    <Button
                      variant="secondary"
                      onClick={() =>
                        setModal({
                          open: true,
                          title: "Action details",
                          body: (
                            <div className="text-sm text-gray-600">
                              Hook this into your “review” modal. Include auditability: users affected, last activity, approvals,
                              and rollback plan.
                            </div>
                          ),
                        })
                      }
                    >
                      Review
                    </Button>
                    <Button onClick={() => apply(a.id)}>Apply</Button>
                  </>
                ) : (
                  <Pill tone="green">Applied</Pill>
                )}
                <KebabMenu
                  items={[
                    { label: "Snooze 7 days (mock)", onClick: () => alert("Snoozed (mock).") },
                    { label: "Mark false positive (mock)", onClick: () => alert("Marked (mock).") },
                  ]}
                />
              </div>
            </div>
          ))}
        </div>
      </Card>

      <Modal open={modal.open} title={modal.title} onClose={() => setModal({ open: false, title: "", body: null })}>
        {modal.body}
        <div className="mt-4 flex justify-end">
          <Button variant="secondary" onClick={() => setModal({ open: false, title: "", body: null })}>
            Close
          </Button>
        </div>
      </Modal>
    </Page>
  );
}

function Licenses() {
  const [rows, setRows] = useState(seed.licenses);
  const [filter, setFilter] = useState("all");
  const [modal, setModal] = useState({ open: false, title: "", body: null });

  const filtered = useMemo(() => {
    if (filter === "idle") return rows.filter((r) => r.lastActivityDays >= 30);
    if (filter === "unused") return rows.filter((r) => r.usedSeats / r.seats < 0.6);
    return rows;
  }, [rows, filter]);

  const reclaim = (id) => {
    setRows((prev) => prev.map((r) => (r.id === id ? { ...r, seats: Math.max(r.usedSeats, r.seats - 1) } : r)));
    setModal({ open: true, title: "Savings", body: <div className="text-sm text-gray-600">Reclaimed 1 seat. Estimated savings: €192/year (demo).</div> });
  };

  const autoReclaimAll = () => {
    const targets = rows.filter((r) => r.lastActivityDays >= 30 && r.seats - r.usedSeats > 0);
    if (targets.length === 0) {
      setModal({ open: true, title: "Auto-Reclaim", body: <div className="text-sm text-gray-600">No safe reclaim candidates found (demo rules).</div> });
      return;
    }
    setRows((prev) =>
      prev.map((r) => {
        const safe = r.lastActivityDays >= 30 && r.seats - r.usedSeats > 0;
        return safe ? { ...r, seats: Math.max(r.usedSeats, r.seats - 1) } : r;
      })
    );
    setModal({
      open: true,
      title: "Auto-Reclaim Complete",
      body: <div className="text-sm text-gray-600">Applied reclaim policy to {targets.length} tools. (Demo action)</div>,
    });
  };

  const exportCsv = () => {
    const header = ["vendor", "plan", "seats", "usedSeats", "lastActivityDays", "costPerSeat"];
    const lines = filtered.map((r) => [r.vendor, r.plan, r.seats, r.usedSeats, r.lastActivityDays, r.costPerSeat].join(","));
    const csv = [header.join(","), ...lines].join("\n");
    const blob = new Blob([csv], { type: "text/csv;charset=utf-8;" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "licenses.csv";
    a.click();
    URL.revokeObjectURL(url);
  };

  return (
    <Page
      title="License Management"
      subtitle="Find idle seats, reclaim safely, and prove savings"
      right={
        <div className="flex gap-2 items-center">
          <select className="border rounded-xl px-3 py-2 text-sm bg-white" value={filter} onChange={(e) => setFilter(e.target.value)}>
            <option value="all">All</option>
            <option value="idle">Idle (≥30d)</option>
            <option value="unused">Underused (&lt;60%)</option>
          </select>
          <Button variant="secondary" onClick={exportCsv}>Export CSV</Button>
          <Button onClick={autoReclaimAll}>Auto-Reclaim All</Button>
        </div>
      }
    >
      <Card title="Licenses (demo)">
        <div className="overflow-auto">
          <table className="min-w-full text-sm">
            <thead className="text-xs text-gray-500">
              <tr className="border-b">
                <th className="text-left py-2 pr-3">Vendor</th>
                <th className="text-left py-2 pr-3">Plan</th>
                <th className="text-right py-2 pr-3">Seats</th>
                <th className="text-right py-2 pr-3">Used</th>
                <th className="text-right py-2 pr-3">Last activity</th>
                <th className="text-right py-2 pr-3">Cost/seat</th>
                <th className="text-right py-2 pr-3">Actions</th>
              </tr>
            </thead>
            <tbody>
              {filtered.map((r) => {
                const idle = r.lastActivityDays >= 30;
                const wasteSeats = Math.max(0, r.seats - r.usedSeats);
                return (
                  <tr key={r.id} className="border-b">
                    <td className="py-2 pr-3">
                      <div className="font-medium">{r.vendor}</div>
                      <div className="text-xs text-gray-500">{r.owner} owner • waste seats: {wasteSeats}</div>
                    </td>
                    <td className="py-2 pr-3">{r.plan}</td>
                    <td className="py-2 pr-3 text-right">{r.seats}</td>
                    <td className="py-2 pr-3 text-right">{r.usedSeats}</td>
                    <td className="py-2 pr-3 text-right">
                      {idle ? <Pill tone="yellow">{r.lastActivityDays}d</Pill> : <Pill tone="green">{r.lastActivityDays}d</Pill>}
                    </td>
                    <td className="py-2 pr-3 text-right">{formatCurrency(r.costPerSeat, seed.company.currency)}</td>
                    <td className="py-2 pr-3 text-right">
                      <div className="flex justify-end gap-2">
                        <Button variant="secondary" onClick={() => setModal({ open: true, title: "Details", body: <div className="text-sm text-gray-600">Show seat-level users + activity + approvals here.</div> })}>
                          Review
                        </Button>
                        <Button onClick={() => reclaim(r.id)}>Reclaim</Button>
                        <KebabMenu
                          items={[
                            { label: "Set reclaim policy (mock)", onClick: () => alert("Policy editor (mock).") },
                            { label: "View audit log (mock)", onClick: () => alert("Audit log (mock).") },
                          ]}
                        />
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </Card>

      <Modal open={modal.open} title={modal.title} onClose={() => setModal({ open: false, title: "", body: null })}>
        {modal.body}
        <div className="mt-4 flex justify-end">
          <Button variant="secondary" onClick={() => setModal({ open: false, title: "", body: null })}>Close</Button>
        </div>
      </Modal>
    </Page>
  );
}

function OverlapScanner() {
  const overlaps = useMemo(
    () => [
      { category: "Docs/Wiki", tools: ["Notion", "Confluence"], monthlyCost: 3800, recommendation: "Consolidate to one knowledge system." },
      { category: "Whiteboarding", tools: ["Miro", "FigJam"], monthlyCost: 1200, recommendation: "Standardize on one to reduce seats + admin overhead." },
      { category: "Video", tools: ["Zoom", "Google Meet"], monthlyCost: 2100, recommendation: "Reduce paid Zoom seats if Meet covers most use-cases." },
    ],
    []
  );

  return (
    <Page title="Tool Overlap Scanner" subtitle="Detect duplicates and consolidation opportunities">
      <Card title="Overlaps (demo)">
        <div className="space-y-3">
          {overlaps.map((o, idx) => (
            <div key={idx} className="p-3 rounded-2xl border bg-white">
              <div className="flex items-center justify-between">
                <div className="font-medium">{o.category}</div>
                <Pill tone="yellow">{formatCurrency(o.monthlyCost, seed.company.currency)}/mo</Pill>
              </div>
              <div className="text-sm text-gray-600 mt-1">Tools: {o.tools.join(" + ")}</div>
              <div className="text-sm mt-2">{o.recommendation}</div>
              <div className="mt-3 flex gap-2">
                <Button onClick={() => alert("Create consolidation project (mock).")}>Create project</Button>
                <Button variant="secondary" onClick={() => alert("Open usage comparison (mock).")}>Compare usage</Button>
              </div>
            </div>
          ))}
        </div>
      </Card>
    </Page>
  );
}

function Renewals() {
  const [view, setView] = useState("list"); // list | calendar
  const [selected, setSelected] = useState(null);

  const negotiateTemplate = (vendor, amount, date) => {
    return `Subject: Renewal review for ${vendor}\n\nHi team,\n\nWe’re reviewing our renewal for ${vendor} (current annual: €${amount.toLocaleString()}, renewal date: ${date}).\n\nBefore we proceed, please share:\n- Current best pricing for our seat count and usage\n- Available discounts (term, multi-product, annual prepay)\n- Options to remove unused add-ons and align to active users\n\nWe’re also evaluating alternatives and will need the strongest offer to renew.\n\nThanks,\nFinance / Procurement`;
  };

  return (
    <Page
      title="Renewal Alerts"
      subtitle="Never miss renewals — prevent surprise charges and negotiate better"
      right={
        <div className="flex gap-2 items-center">
          <Button variant={view === "list" ? "primary" : "secondary"} onClick={() => setView("list")}>List</Button>
          <Button variant={view === "calendar" ? "primary" : "secondary"} onClick={() => setView("calendar")}>Calendar</Button>
        </div>
      }
    >
      {view === "calendar" ? (
        <Card title="Calendar (demo)">
          <div className="text-sm text-gray-600">Calendar UI placeholder. Hook into your existing calendar component.</div>
          <div className="mt-3 grid md:grid-cols-3 gap-3">
            {seed.renewals.map((r) => (
              <div key={r.id} className="p-3 rounded-2xl border bg-white">
                <div className="font-medium">{r.vendor}</div>
                <div className="text-xs text-gray-500 mt-1">{r.renewalDate} • {formatCurrency(r.amount, seed.company.currency)}</div>
                <div className="mt-2">
                  <Button variant="secondary" onClick={() => setSelected(r)}>Review</Button>
                </div>
              </div>
            ))}
          </div>
        </Card>
      ) : (
        <Card title="Upcoming renewals (demo)">
          <div className="space-y-2">
            {seed.renewals.map((r) => (
              <div key={r.id} className="p-3 rounded-2xl border bg-white flex items-center justify-between">
                <div>
                  <div className="font-medium">{r.vendor}</div>
                  <div className="text-xs text-gray-500 mt-1">
                    Renewal: {r.renewalDate} • Amount: {formatCurrency(r.amount, seed.company.currency)} • Auto-renew: {r.autoRenew ? "ON" : "OFF"} • Owner: {r.owner}
                  </div>
                </div>
                <div className="flex gap-2 items-center">
                  <Pill tone={r.risk === "high" ? "red" : r.risk === "med" ? "yellow" : "green"}>{r.risk} risk</Pill>
                  <Button variant="secondary" onClick={() => setSelected(r)}>Review</Button>
                  <KebabMenu
                    items={[
                      {
                        label: "Negotiate (copy email)",
                        onClick: async () => {
                          const t = negotiateTemplate(r.vendor, r.amount, r.renewalDate);
                          try { await navigator.clipboard.writeText(t); } catch {}
                          alert("Negotiation email copied to clipboard (if supported).");
                        },
                      },
                      { label: "Create task (mock)", onClick: () => alert("Task created (mock).") },
                    ]}
                  />
                </div>
              </div>
            ))}
          </div>
        </Card>
      )}

      <Modal open={!!selected} title={selected ? `${selected.vendor} — Renewal Details` : ""} onClose={() => setSelected(null)}>
        {selected && (
          <>
            <div className="text-sm text-gray-600">
              Amount: {formatCurrency(selected.amount, seed.company.currency)} • Date: {selected.renewalDate} • Auto-renew: {selected.autoRenew ? "ON" : "OFF"}
            </div>
            <div className="mt-3 p-3 rounded-2xl border bg-gray-50 text-sm">
              <div className="font-medium">Playbook</div>
              <ul className="mt-2 space-y-1">
                <li>• Validate active users vs seats</li>
                <li>• Remove add-ons not used</li>
                <li>• Ask for term discount + price protection</li>
                <li>• Compare alternatives (overlap scanner)</li>
              </ul>
            </div>
            <div className="mt-4 flex justify-end gap-2">
              <Button variant="secondary" onClick={() => setSelected(null)}>Close</Button>
              <Button onClick={() => alert("Open negotiate modal / email composer (hook to your modal system).")}>Negotiate</Button>
            </div>
          </>
        )}
      </Modal>
    </Page>
  );
}

function ContractIntelligence() {
  const [file, setFile] = useState(null);
  const [extracted, setExtracted] = useState(null);

  const analyze = () => {
    setExtracted({
      vendor: "Salesforce",
      term: "12 months",
      autoRenew: "Yes (30-day notice)",
      terminationWindow: "30 days before renewal",
      priceIncrease: "Up to 8% annually (example)",
      minimumCommitment: "200 seats",
      notes: "Flag: auto-renew ON + high spend. Recommend negotiation + usage audit.",
    });
  };

  return (
    <Page title="Contract Intelligence" subtitle="Upload contracts and extract renewal clauses instantly">
      <Card title="Upload contract (demo)">
        <input type="file" className="text-sm" onChange={(e) => setFile(e.target.files?.[0] || null)} />
        <div className="mt-3 flex gap-2">
          <Button disabled={!file} onClick={analyze}>Analyze</Button>
          <Button variant="secondary" onClick={() => { setFile(null); setExtracted(null); }}>Reset</Button>
        </div>
        <div className="text-xs text-gray-500 mt-2">
          Replace demo extraction with PDF parsing + clause extraction once you integrate backend.
        </div>
      </Card>

      {extracted && (
        <div className="mt-4 grid md:grid-cols-2 gap-4">
          <Card title="Extracted terms">
